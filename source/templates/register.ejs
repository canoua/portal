<%- include('includes/header.ejs') %>
<form class="form" action="/register" method="post">
  <h1 class="form-title">Регистрация</h1>
  <input
    class="form-input"
    placeholder="Имя"
    name="username"
    value="<%= body.username || '' %>"
  />

  <input
    class="form-input"
    placeholder="Пароль"
    name="password"
    type="password"
    value="<%= body.password || '' %>"
  />

  <input
    class="form-input"
    placeholder="Повтор пароля"
    name="password2"
    type="password"
    value="<%= body.password2 || '' %>"
  />

  <input class="form-submit" type="submit" value="зарегистрировать" />
</form>
<%- include('includes/footer.ejs') %>
